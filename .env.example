# ──────────────────────────────────────────────────────────────────────────
# SafeAI — example environment configuration
#
# Copy this file to `.env` and fill in real values for local development.
# `.env` is git-ignored and MUST NEVER be committed. No real secrets here.
# All values below are placeholders / safe defaults.
# ──────────────────────────────────────────────────────────────────────────

# --- Application ---
SAFEAI_ENVIRONMENT=development          # development | staging | production
SAFEAI_APP_NAME=SafeAI
SAFEAI_VERSION=0.1.0
SAFEAI_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# --- Security (JWT) ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Required in production; the app refuses to start in production without it.
SAFEAI_JWT_SECRET_KEY=change-me-in-production-use-a-48-byte-random-string
SAFEAI_JWT_ALGORITHM=HS256
SAFEAI_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database (PostgreSQL) ---
# Driver: psycopg (psycopg3). Format:
#   postgresql+psycopg://<user>:<password>@<host>:<port>/<db>
SAFEAI_DATABASE_URL=postgresql+psycopg://safeai:safeai@localhost:5432/safeai

# Values used by the Postgres container in docker-compose.yml.
# Keep these in sync with SAFEAI_DATABASE_URL above.
POSTGRES_USER=safeai
POSTGRES_PASSWORD=safeai
POSTGRES_DB=safeai

# --- CORS (frontend origin allowed to call the API) ---
SAFEAI_CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) ---
# Public base URL the browser uses to reach the API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
